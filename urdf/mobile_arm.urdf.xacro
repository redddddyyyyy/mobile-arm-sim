<?xml version="1.0"?>
<robot name="mobile_arm" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- ============================================================== -->
  <!-- Properties                                                     -->
  <!-- ============================================================== -->
  <xacro:property name="base_length"    value="0.40"/>
  <xacro:property name="base_width"     value="0.28"/>
  <xacro:property name="base_height"    value="0.08"/>
  <xacro:property name="base_mass"      value="5.0"/>

  <xacro:property name="wheel_radius"    value="0.05"/>
  <xacro:property name="wheel_thickness" value="0.04"/>
  <xacro:property name="wheel_mass"      value="0.3"/>
  <xacro:property name="wheel_xoff"      value="0.14"/>
  <xacro:property name="wheel_yoff"      value="${base_width/2 + wheel_thickness/2 + 0.005}"/>

  <!-- ============================================================== -->
  <!-- Materials                                                      -->
  <!-- ============================================================== -->
  <material name="grey">   <color rgba="0.4 0.4 0.4 1.0"/></material>
  <material name="black">  <color rgba="0.1 0.1 0.1 1.0"/></material>
  <material name="blue">   <color rgba="0.2 0.4 0.85 1.0"/></material>
  <material name="orange"> <color rgba="1.0 0.55 0.0 1.0"/></material>

  <!-- ============================================================== -->
  <!-- Inertia macros                                                 -->
  <!-- ============================================================== -->
  <xacro:macro name="box_inertia" params="m x y z">
    <inertial>
      <mass value="${m}"/>
      <inertia ixx="${m*(y*y+z*z)/12}" ixy="0" ixz="0"
               iyy="${m*(x*x+z*z)/12}" iyz="0"
               izz="${m*(x*x+y*y)/12}"/>
    </inertial>
  </xacro:macro>

  <xacro:macro name="cylinder_inertia" params="m r h">
    <inertial>
      <mass value="${m}"/>
      <inertia ixx="${m*(3*r*r+h*h)/12}" ixy="0" ixz="0"
               iyy="${m*(3*r*r+h*h)/12}" iyz="0"
               izz="${m*r*r/2}"/>
    </inertial>
  </xacro:macro>

  <!-- ============================================================== -->
  <!-- base_footprint -> base_link                                    -->
  <!-- ============================================================== -->
  <link name="base_footprint"/>

  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child  link="base_link"/>
    <origin xyz="0 0 ${wheel_radius}" rpy="0 0 0"/>
  </joint>

  <link name="base_link">
    <visual>
      <origin xyz="0 0 ${base_height/2}" rpy="0 0 0"/>
      <geometry><box size="${base_length} ${base_width} ${base_height}"/></geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <origin xyz="0 0 ${base_height/2}" rpy="0 0 0"/>
      <geometry><box size="${base_length} ${base_width} ${base_height}"/></geometry>
    </collision>
    <xacro:box_inertia m="${base_mass}" x="${base_length}" y="${base_width}" z="${base_height}"/>
  </link>

  <gazebo reference="base_link">
    <material>Gazebo/Blue</material>
  </gazebo>

  <!-- ============================================================== -->
  <!-- Wheels: FIXED joints, visual-only (planar_move teleports base) -->
  <!-- Fixed avoids ros2_control complications and is identical       -->
  <!-- visually since planar_move never spins the wheels anyway.      -->
  <!-- ============================================================== -->
  <xacro:macro name="mecanum_wheel" params="prefix x y">
    <link name="${prefix}_wheel">
      <visual>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
        <geometry><cylinder length="${wheel_thickness}" radius="${wheel_radius}"/></geometry>
        <material name="black"/>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
        <geometry><cylinder length="${wheel_thickness}" radius="${wheel_radius}"/></geometry>
      </collision>
      <xacro:cylinder_inertia m="${wheel_mass}" r="${wheel_radius}" h="${wheel_thickness}"/>
    </link>

    <joint name="${prefix}_wheel_joint" type="fixed">
      <parent link="base_link"/>
      <child  link="${prefix}_wheel"/>
      <origin xyz="${x} ${y} 0" rpy="0 0 0"/>
    </joint>

    <gazebo reference="${prefix}_wheel">
      <material>Gazebo/FlatBlack</material>
    </gazebo>
  </xacro:macro>

  <xacro:mecanum_wheel prefix="front_left"  x=" ${wheel_xoff}" y=" ${wheel_yoff}"/>
  <xacro:mecanum_wheel prefix="front_right" x=" ${wheel_xoff}" y="-${wheel_yoff}"/>
  <xacro:mecanum_wheel prefix="rear_left"   x="-${wheel_xoff}" y=" ${wheel_yoff}"/>
  <xacro:mecanum_wheel prefix="rear_right"  x="-${wheel_xoff}" y="-${wheel_yoff}"/>

  <!-- ============================================================== -->
  <!-- Arm                                                             -->
  <!-- ============================================================== -->
  <link name="arm_base">
    <visual>
      <origin xyz="0 0 0.025" rpy="0 0 0"/>
      <geometry><cylinder length="0.05" radius="0.05"/></geometry>
      <material name="grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.025" rpy="0 0 0"/>
      <geometry><cylinder length="0.05" radius="0.05"/></geometry>
    </collision>
    <xacro:cylinder_inertia m="0.3" r="0.05" h="0.05"/>
  </link>
  <joint name="arm_base_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="arm_base"/>
    <origin xyz="0.05 0 ${base_height}" rpy="0 0 0"/>
  </joint>

  <link name="shoulder_link">
    <visual>
      <origin xyz="0 0 0.04" rpy="0 0 0"/>
      <geometry><cylinder length="0.08" radius="0.035"/></geometry>
      <material name="orange"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.04" rpy="0 0 0"/>
      <geometry><cylinder length="0.08" radius="0.035"/></geometry>
    </collision>
    <xacro:cylinder_inertia m="0.2" r="0.035" h="0.08"/>
  </link>
  <joint name="shoulder_pan_joint" type="revolute">
    <parent link="arm_base"/>
    <child  link="shoulder_link"/>
    <origin xyz="0 0 0.05" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14" upper="3.14" effort="20" velocity="2"/>
    <dynamics damping="0.5" friction="0.1"/>
  </joint>

  <link name="upper_arm_link">
    <visual>
      <origin xyz="0 0 0.075" rpy="0 0 0"/>
      <geometry><box size="0.04 0.04 0.15"/></geometry>
      <material name="orange"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.075" rpy="0 0 0"/>
      <geometry><box size="0.04 0.04 0.15"/></geometry>
    </collision>
    <xacro:box_inertia m="0.2" x="0.04" y="0.04" z="0.15"/>
  </link>
  <joint name="shoulder_lift_joint" type="revolute">
    <parent link="shoulder_link"/>
    <child  link="upper_arm_link"/>
    <origin xyz="0 0 0.08" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.57" upper="1.57" effort="20" velocity="2"/>
    <dynamics damping="0.5" friction="0.1"/>
  </joint>

  <link name="forearm_link">
    <visual>
      <origin xyz="0 0 0.06" rpy="0 0 0"/>
      <geometry><box size="0.035 0.035 0.12"/></geometry>
      <material name="orange"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.06" rpy="0 0 0"/>
      <geometry><box size="0.035 0.035 0.12"/></geometry>
    </collision>
    <xacro:box_inertia m="0.15" x="0.035" y="0.035" z="0.12"/>
  </link>
  <joint name="elbow_joint" type="revolute">
    <parent link="upper_arm_link"/>
    <child  link="forearm_link"/>
    <origin xyz="0 0 0.15" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.5" upper="2.5" effort="20" velocity="2"/>
    <dynamics damping="0.5" friction="0.1"/>
  </joint>

  <link name="wrist_link">
    <visual>
      <origin xyz="0 0 0.025" rpy="0 0 0"/>
      <geometry><cylinder length="0.05" radius="0.025"/></geometry>
      <material name="grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.025" rpy="0 0 0"/>
      <geometry><cylinder length="0.05" radius="0.025"/></geometry>
    </collision>
    <xacro:cylinder_inertia m="0.1" r="0.025" h="0.05"/>
  </link>
  <joint name="wrist_joint" type="revolute">
    <parent link="forearm_link"/>
    <child  link="wrist_link"/>
    <origin xyz="0 0 0.12" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.57" upper="1.57" effort="20" velocity="2"/>
    <dynamics damping="0.5" friction="0.1"/>
  </joint>

  <!-- ============================================================== -->
  <!-- Gripper                                                        -->
  <!-- ============================================================== -->
  <link name="gripper_base">
    <visual>
      <origin xyz="0 0 0.015" rpy="0 0 0"/>
      <geometry><box size="0.06 0.03 0.03"/></geometry>
      <material name="grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.015" rpy="0 0 0"/>
      <geometry><box size="0.06 0.03 0.03"/></geometry>
    </collision>
    <xacro:box_inertia m="0.05" x="0.06" y="0.03" z="0.03"/>
  </link>
  <joint name="gripper_base_joint" type="fixed">
    <parent link="wrist_link"/>
    <child  link="gripper_base"/>
    <origin xyz="0 0 0.05" rpy="0 0 0"/>
  </joint>

  <xacro:macro name="finger" params="prefix sign">
    <link name="${prefix}_finger">
      <visual>
        <origin xyz="0 0 0.025" rpy="0 0 0"/>
        <geometry><box size="0.008 0.01 0.05"/></geometry>
        <material name="black"/>
      </visual>
      <collision>
        <origin xyz="0 0 0.025" rpy="0 0 0"/>
        <geometry><box size="0.008 0.01 0.05"/></geometry>
      </collision>
      <xacro:box_inertia m="0.02" x="0.008" y="0.01" z="0.05"/>
    </link>
    <joint name="${prefix}_finger_joint" type="prismatic">
      <parent link="gripper_base"/>
      <child  link="${prefix}_finger"/>
      <origin xyz="${sign*0.018} 0 0.03" rpy="0 0 0"/>
      <axis xyz="1 0 0"/>
      <limit lower="-0.015" upper="0.005" effort="5" velocity="0.1"/>
      <dynamics damping="1.0" friction="0.1"/>
    </joint>
  </xacro:macro>

  <xacro:finger prefix="left"  sign="-1"/>
  <xacro:finger prefix="right" sign="1"/>

  <!-- ============================================================== -->
  <!-- ros2_control: arm + gripper joints, position-commanded         -->
  <!-- ============================================================== -->
  <ros2_control name="GazeboSystem" type="system">
    <hardware>
      <plugin>gazebo_ros2_control/GazeboSystem</plugin>
    </hardware>

    <joint name="shoulder_pan_joint">
      <command_interface name="position"><param name="min">-3.14</param><param name="max">3.14</param></command_interface>
      <state_interface name="position"><param name="initial_value">0.0</param></state_interface>
      <state_interface name="velocity"/>
    </joint>

    <joint name="shoulder_lift_joint">
      <command_interface name="position"><param name="min">-1.57</param><param name="max">1.57</param></command_interface>
      <state_interface name="position"><param name="initial_value">-0.5</param></state_interface>
      <state_interface name="velocity"/>
    </joint>

    <joint name="elbow_joint">
      <command_interface name="position"><param name="min">-2.5</param><param name="max">2.5</param></command_interface>
      <state_interface name="position"><param name="initial_value">1.2</param></state_interface>
      <state_interface name="velocity"/>
    </joint>

    <joint name="wrist_joint">
      <command_interface name="position"><param name="min">-1.57</param><param name="max">1.57</param></command_interface>
      <state_interface name="position"><param name="initial_value">0.3</param></state_interface>
      <state_interface name="velocity"/>
    </joint>

    <joint name="left_finger_joint">
      <command_interface name="position"><param name="min">-0.015</param><param name="max">0.005</param></command_interface>
      <state_interface name="position"><param name="initial_value">-0.01</param></state_interface>
      <state_interface name="velocity"/>
    </joint>

    <joint name="right_finger_joint">
      <command_interface name="position"><param name="min">-0.015</param><param name="max">0.005</param></command_interface>
      <state_interface name="position"><param name="initial_value">-0.01</param></state_interface>
      <state_interface name="velocity"/>
    </joint>
  </ros2_control>

  <!-- ============================================================== -->
  <!-- Gazebo plugins                                                 -->
  <!-- ============================================================== -->

  <!-- ros2_control plugin: gives us controller_manager + spawnable controllers -->
  <gazebo>
    <plugin filename="libgazebo_ros2_control.so" name="gazebo_ros2_control">
      <parameters>$(find mobile_arm_sim)/config/controllers.yaml</parameters>
    </plugin>
  </gazebo>

  <gazebo>
    <plugin name="gazebo_ros_planar_move" filename="libgazebo_ros_planar_move.so">
      <ros>
        <namespace>/</namespace>
      </ros>
      <update_rate>50</update_rate>
      <publish_rate>10</publish_rate>
      <publish_odom>true</publish_odom>
      <publish_odom_tf>true</publish_odom_tf>
      <odometry_frame>odom</odometry_frame>
      <robot_base_frame>base_footprint</robot_base_frame>
      <covariance_x>0.0001</covariance_x>
      <covariance_y>0.0001</covariance_y>
      <covariance_yaw>0.01</covariance_yaw>
    </plugin>
  </gazebo>

</robot>
