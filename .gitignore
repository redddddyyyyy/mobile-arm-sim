# colcon build artifacts (these live one level up at the workspace root,
# but ignore here too in case anyone runs colcon from inside the package)
build/
install/
log/

# Python
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/

# Editor / OS
.vscode/
.idea/
.claude/
*.swp
*.swo
.DS_Store

# Generated maps (regenerated by slam_toolbox); keep saved maps explicitly
maps/*.pgm.bak

# Personal working notes — not for the repo
instructions.md
PROGRESS.md
docs/checkpoint_report.*

# Screen recordings are far too big for git; demo gifs are cut from them
*.webm
